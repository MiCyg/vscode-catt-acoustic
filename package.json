{
  "name": "cat-acoustic",
  "displayName": "CATT-Acoustic Syntax Helper",
  "description": "Syntax highlighting and language support for CATT-Acoustic geometry (.geo) and location (.loc) files",
  "repository": "https://github.com/MiCyg/vscode-catt-acoustic.git",
  "version": "0.4.0",
  "author": {
    "name": "MiCyg"
  },
  "icon": "images/icon.png",
  "keywords": [
    "catt",
    "acoustics",
    "acoustic simulation",
    "geo",
    "loc",
    "ray tracing",
    "audio",
    "simulation"
  ],
  "homepage": "https://github.com/MiCyg/vscode-catt-acoustic",
  "bugs": {
    "url": "https://github.com/MiCyg/vscode-catt-acoustic/issues"
  },
  "license": "MIT",
  "publisher": "MiCyg-VSCode",
  "engines": {
    "vscode": "^1.116.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "cattgeo",
        "aliases": ["CATT GEO"],
        "extensions": [".geo", ".geo.bkp"],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "cattloc",
        "aliases": ["CATT LOC"],
        "extensions": [".loc", ".loc.bkp"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "cattgeo",
        "scopeName": "source.cattgeo",
        "path": "./syntaxes/geo.tmLanguage.json"
      },
      {
        "language": "cattloc",
        "scopeName": "source.cattloc",
        "path": "./syntaxes/loc.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "cattloc",
        "path": "./snippets/cattloc.snippets.json"
      },
      {
        "language": "cattgeo",
        "path": "./snippets/cattgeo.snippets.json"
      }
    ]
  }
}
