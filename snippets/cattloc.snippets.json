{
  "SOURCE block": {
    "prefix": "SOURCE",
    "body": [
      "SOURCE ${1:id}",
      "\tDIRECTIVITY = ${2:\"omni\"}",
      "\tPOS = ${3:0 0 0}",
      "\tAIMPOS = ${4:0 0 0}",
      "\t; AIMANGLES = 0 0",
	  "\tLp1m_a = < ${5:94 94 94 94 94 94} >",
      "\t; Optional:",
      "\t;MICSENSITIVITY = s",
      "\t;GAIN = < G125 .. G4k [ : G8k G16k ] >",
      "\t;DELAY = d",
      "\t;POLARITYREVERSAL",
      "\t;OFF",
      "END"
    ],
    "description": "Create a SOURCE block with END"
  },
  "RECEIVER block": {
    "prefix": "RECEIVER",
    "body": [
      "${1:00} ${2:0.0} ${3:0.0} ${4:0.0}"
    ],
    "description": "Create a RECEIVER block"
  },
  "Simple SOURCE": {
    "prefix": "SRC",
    "body": [
      "SOURCE ${1:id}",
      "\t$0",
      "END"
    ],
    "description": "Quick SOURCE...END block"
  }
}
