{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "catt loc",
	"scopeName": "source.cattloc",
	"patterns": [
		{
			"include": "#comments"
		},
		{
			"include": "#source-blocks"
		},
		{
			"include": "#directives"
		},
		{
			"include": "#sections"
		},
		{
			"include": "#keywords"
		},
		{
			"include": "#parameters"
		},
		{
			"include": "#functions"
		},
		{
			"include": "#receivers"
		},
		{
			"include": "#strings"
		},
		{
			"include": "#identifiers"
		},
		{
			"include": "#numbers"
		},
		{
			"include": "#operators"
		}
	],
	"repository": {
		"comments": {
			"patterns": [
				{
					"name": "comment.line.semicolon.cattloc",
					"match": ";.*$"
				}
			]
		},
		"source-blocks": {
			"patterns": [
				{
					"name": "meta.source-block.cattloc",
					"begin": "^(SOURCE)\\b",
					"end": "^(END)\\b",
					"beginCaptures": {
						"1": {
							"name": "keyword.control.source-start.cattloc"
						}
					},
					"endCaptures": {
						"1": {
							"name": "keyword.control.source-end.cattloc"
						}
					},
					"patterns": [
						{
							"include": "#comments"
						},
						{
							"include": "#strings"
						},
						{
							"include": "#source-parameters"
						},
						{
							"include": "#keywords"
						},
						{
							"include": "#identifiers"
						},
						{
							"include": "#numbers"
						},
						{
							"include": "#operators"
						}
					]
				}
			]
		},
		"source-parameters": {
			"patterns": [
				{
					"name": "keyword.control.source-param.cattloc",
					"match": "\\b(DIRECTIVITY|OMNI|POS|AIMPOS|AIMANGLES|LvIn|GAIN|Lp1m_a|Gain_a|Lp1m_ea|Delay_e)\\b"
				},
				{
					"name": "variable.other.assignment.cattloc",
					"match": "([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\=)"
				}
			]
		},
		"directives": {
			"patterns": [
				{
					"name": "keyword.control.directive.cattloc",
					"match": "\\b(LOCAL|GLOBAL|GETLOCAL|GETGLOBAL|SCALE|INCLUDE)\\b"
				},
				{
					"name": "keyword.preprocessor.include.cattloc",
					"match": "#I\\b"
				},
				{
					"name": "keyword.control.conditional.cattloc",
					"match": "\\b(IF|THEN|ELSE|ENDIF)\\b"
				},
				{
					"name": "keyword.control.diagnostic.cattloc",
					"match": "\\b(SAY|DEBUG|RETURN)\\b"
				},
				{
					"name": "keyword.control.info.cattloc",
					"match": "\\b(INFO|MIN|MAX)\\b"
				}
			]
		},
		"sections": {
			"patterns": [
				{
					"name": "keyword.control.section.cattloc",
					"match": "\\b(SOURCEDEFS|SOURCE|RECEIVERS)\\b"
				}
			]
		},
		"keywords": {
			"patterns": [
				{
					"name": "keyword.control.source.cattloc",
					"match": "\\b(DIRECTIVITY|OMNI|POS|AIMPOS|AIMANGLES|END|LvIn|GAIN)\\b"
				},
				{
					"name": "keyword.control.receiver.cattloc",
					"match": "\\b(OVERRIDE)\\b"
				},
				{
					"name": "keyword.control.axis.cattloc",
					"match": "\\b(hx|hy|hz)\\b"
				}
			]
		},
		"parameters": {
			"patterns": [
				{
					"name": "variable.parameter.source.cattloc",
					"match": "\\b(Lp1m_a|Gain_a|Lp1m_ea|Delay_e|Lp_voice_normal|Lp_voice_loud|Lp_pink)\\b"
				},
				{
					"name": "variable.other.assignment.cattloc",
					"match": "([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\=)"
				}
			]
		},
		"functions": {
			"patterns": [
				{
					"name": "entity.name.function.math.cattloc",
					"match": "\\b(sin|cos|tan|sqrt|abs|exp|log)\\s*(?=\\()"
				},
				{
					"name": "entity.name.function.loop.cattloc",
					"match": "\\b(recloop|recline|recwalk)\\s*(?=\\()"
				},
				{
					"name": "punctuation.section.parens.cattloc",
					"match": "[()]"
				}
			]
		},
		"strings": {
			"patterns": [
				{
					"name": "string.quoted.double.cattloc",
					"begin": "\"",
					"end": "\"",
					"patterns": [
						{
							"name": "constant.character.escape.cattloc",
							"match": "\\\\."
						}
					]
				},
				{
					"name": "string.unquoted.filename.cattloc",
					"match": "[A-Za-z0-9_\\-./]+\\.(SD0|MRK|LOC|GEO)"
				}
			]
		},
		"numbers": {
			"patterns": [
				{
					"name": "constant.numeric.float.cattloc",
					"match": "-?\\d+\\.\\d+"
				},
				{
					"name": "constant.numeric.integer.cattloc",
					"match": "-?\\d+"
				}
			]
		},
		"operators": {
			"patterns": [
				{
					"name": "keyword.operator.cattloc",
					"match": "[=+\\-*/<>]"
				}
			]
		},
		"identifiers": {
			"patterns": [
				{
					"name": "variable.other.cattloc",
					"match": "[A-Za-z_][A-Za-z0-9_\\-]*"
				}
			]
		},
		"receivers": {
			"patterns": [
				{
					"name": "meta.receiver.cattloc",
					"begin": "^(\\d{2})\\s+",
					"end": "$",
					"beginCaptures": {
						"1": {
							"name": "entity.name.tag.receiver-id.cattloc"
						}
					},
					"patterns": [
						{
							"name": "constant.numeric.float.coordinate.cattloc",
							"match": "-?\\d+\\.\\d+"
						},
						{
							"name": "constant.numeric.integer.cattloc",
							"match": "-?\\d+(?!\\d)"
						}
					]
				}
			]
		}
	}
}
